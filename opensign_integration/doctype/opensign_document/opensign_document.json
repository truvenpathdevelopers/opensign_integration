{
    "name": "OpenSign Document",
    "module": "OpenSign Integration",
    "doctype": "DocType",
    "document_type": "Document",
    "naming_rule": "Expression",
    "autoname": "OSIGN-.######",
    "track_changes": 1,
    "engine": "InnoDB",
    "fields": [
        {
            "fieldname": "document_title",
            "fieldtype": "Data",
            "label": "Document Title",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "status",
            "fieldtype": "Select",
            "label": "Status",
            "options": "Draft\nSent\nIn Progress\nPartially Signed\nCompleted\nDeclined\nRevoked\nExpired",
            "default": "Draft",
            "in_list_view": 1,
            "in_standard_filter": 1
        },
        {
            "fieldname": "column_break_1",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "opensign_document_id",
            "fieldtype": "Data",
            "label": "OpenSign Document ID",
            "read_only": 1
        },
        {
            "fieldname": "signing_url",
            "fieldtype": "Data",
            "label": "Signing URL",
            "read_only": 1
        },
        {
            "fieldname": "source_section",
            "fieldtype": "Section Break",
            "label": "Source Document"
        },
        {
            "fieldname": "pdf_file",
            "fieldtype": "Attach",
            "label": "PDF File",
            "description": "Upload PDF to send for signature"
        },
        {
            "fieldname": "linked_doctype",
            "fieldtype": "Link",
            "label": "Linked DocType",
            "options": "DocType"
        },
        {
            "fieldname": "linked_document",
            "fieldtype": "Dynamic Link",
            "label": "Linked Document",
            "options": "linked_doctype"
        },
        {
            "fieldname": "column_break_src",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "template_id",
            "fieldtype": "Data",
            "label": "Template ID",
            "description": "OpenSign Template ID if using template"
        },
        {
            "fieldname": "folder_id",
            "fieldtype": "Data",
            "label": "Folder ID",
            "description": "OpenSign folder for organization"
        },
        {
            "fieldname": "signers_section",
            "fieldtype": "Section Break",
            "label": "Signers"
        },
        {
            "fieldname": "signers",
            "fieldtype": "Table",
            "label": "Signers",
            "options": "OpenSign Signer"
        },
        {
            "fieldname": "options_section",
            "fieldtype": "Section Break",
            "label": "Options"
        },
        {
            "fieldname": "send_in_order",
            "fieldtype": "Check",
            "label": "Send in Order",
            "description": "Signers must sign in sequence"
        },
        {
            "fieldname": "expiry_days",
            "fieldtype": "Int",
            "label": "Expiry Days",
            "description": "Days until document expires"
        },
        {
            "fieldname": "auto_send",
            "fieldtype": "Check",
            "label": "Auto Send on Create",
            "description": "Automatically send for signature when document is created"
        },
        {
            "fieldname": "column_break_opt",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "sent_at",
            "fieldtype": "Datetime",
            "label": "Sent At",
            "read_only": 1
        },
        {
            "fieldname": "completed_at",
            "fieldtype": "Datetime",
            "label": "Completed At",
            "read_only": 1
        },
        {
            "fieldname": "expires_at",
            "fieldtype": "Date",
            "label": "Expires At",
            "read_only": 1
        },
        {
            "fieldname": "signed_document_section",
            "fieldtype": "Section Break",
            "label": "Signed Document"
        },
        {
            "fieldname": "signed_pdf",
            "fieldtype": "Attach",
            "label": "Signed PDF",
            "read_only": 1
        },
        {
            "fieldname": "completion_certificate",
            "fieldtype": "Attach",
            "label": "Completion Certificate",
            "read_only": 1
        },
        {
            "fieldname": "decline_reason",
            "fieldtype": "Small Text",
            "label": "Decline Reason",
            "read_only": 1,
            "depends_on": "eval:doc.status=='Declined'"
        },
        {
            "fieldname": "activity_section",
            "fieldtype": "Section Break",
            "label": "Activity Log",
            "collapsible": 1
        },
        {
            "fieldname": "activity_log",
            "fieldtype": "Table",
            "label": "Activity Log",
            "options": "OpenSign Activity Log",
            "read_only": 1
        }
    ],
    "permissions": [
        {
            "role": "System Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1
        },
        {
            "role": "All",
            "read": 1,
            "write": 1,
            "create": 1
        }
    ],
    "sort_field": "modified",
    "sort_order": "DESC"
}
