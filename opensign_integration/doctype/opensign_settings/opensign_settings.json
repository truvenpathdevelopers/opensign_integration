{
    "name": "OpenSign Settings",
    "module": "OpenSign Integration",
    "doctype": "DocType",
    "document_type": "Setup",
    "issingle": 1,
    "track_changes": 0,
    "engine": "InnoDB",
    "fields": [
        {
            "fieldname": "api_section",
            "fieldtype": "Section Break",
            "label": "API Configuration"
        },
        {
            "fieldname": "api_token",
            "fieldtype": "Password",
            "label": "API Token",
            "reqd": 1,
            "description": "Generate your API token from OpenSign Settings > API Token"
        },
        {
            "fieldname": "sandbox_mode",
            "fieldtype": "Check",
            "label": "Sandbox Mode",
            "description": "Use sandbox environment for testing"
        },
        {
            "fieldname": "base_url",
            "fieldtype": "Data",
            "label": "Base URL",
            "description": "Leave empty to use default OpenSign API URL"
        },
        {
            "fieldname": "column_break_1",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "account_email",
            "fieldtype": "Data",
            "label": "Account Email",
            "read_only": 1
        },
        {
            "fieldname": "account_name",
            "fieldtype": "Data",
            "label": "Account Name",
            "read_only": 1
        },
        {
            "fieldname": "api_credits",
            "fieldtype": "Int",
            "label": "API Credits Remaining",
            "read_only": 1
        },
        {
            "fieldname": "webhook_section",
            "fieldtype": "Section Break",
            "label": "Webhook Configuration"
        },
        {
            "fieldname": "webhook_id",
            "fieldtype": "Data",
            "label": "Webhook ID",
            "read_only": 1
        },
        {
            "fieldname": "webhook_url",
            "fieldtype": "Data",
            "label": "Webhook URL",
            "read_only": 1
        },
        {
            "fieldname": "column_break_2",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "setup_webhook",
            "fieldtype": "Button",
            "label": "Setup Webhook",
            "options": "setup_webhook"
        },
        {
            "fieldname": "defaults_section",
            "fieldtype": "Section Break",
            "label": "Default Settings"
        },
        {
            "fieldname": "default_expiry_days",
            "fieldtype": "Int",
            "label": "Default Expiry Days",
            "default": "30",
            "description": "Default number of days before document expires"
        },
        {
            "fieldname": "send_in_order",
            "fieldtype": "Check",
            "label": "Send in Order by Default",
            "description": "Enable sequential signing by default"
        },
        {
            "fieldname": "include_date_widget",
            "fieldtype": "Check",
            "label": "Include Date Widget",
            "default": 1,
            "description": "Add date widget alongside signature by default"
        },
        {
            "fieldname": "column_break_3",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "date_format",
            "fieldtype": "Select",
            "label": "Date Format",
            "options": "mm/dd/yyyy\ndd-mm-yyyy\nyyyy-mm-dd\nmm.dd.yyyy\nmm-dd-yyyy\nmmm dd, yyyy\nmmmm dd, yyyy\ndd mmm, yyyy\ndd mmmm, yyyy\ndd/mm/yyyy\ndd.mm.yyyy",
            "default": "mm/dd/yyyy"
        },
        {
            "fieldname": "auto_sync_status",
            "fieldtype": "Check",
            "label": "Auto Sync Document Status",
            "default": 1,
            "description": "Automatically sync document statuses via scheduled job"
        }
    ],
    "permissions": [
        {
            "role": "System Manager",
            "read": 1,
            "write": 1,
            "create": 1
        }
    ],
    "sort_field": "modified",
    "sort_order": "DESC"
}
